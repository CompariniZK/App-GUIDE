# ─── Boussole Backend — Required environment variables ──────────────────────
# Copy this file to `.env` for local dev, or paste each value into your
# hosting provider's dashboard (Railway / Render / Fly.io).

# ── Required ───────────────────────────────────────────────────────────────

# Anthropic Claude API key — used by /api/chat (RAG with Claude)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx

# Groq API key — used by /api/groq/chat (Llama 3.3 70B)
# Get one at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxx

# ── Optional ───────────────────────────────────────────────────────────────

# Port the HTTP server listens on. Railway/Render set this automatically — DO NOT
# hardcode it in production. Default: 3000.
# PORT=3000

# Environment — set to "production" in prod so the server tightens CORS,
# rate limits, and refuses to start without GROQ_API_KEY.
NODE_ENV=development

# Override the Groq model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# CORS allowlist for browsers. Comma-separated origins.
# React Native apps DON'T send an Origin header, so they're allowed regardless.
# This only matters if you build a web version of the app.
# Example: ALLOWED_ORIGINS=https://boussole.it.com,https://app.boussole.it.com
# ALLOWED_ORIGINS=
